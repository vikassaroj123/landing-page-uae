    <!-- Comparison -->
    <section class="section-pad" style="background:#fff;">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="eyebrow">مقارنتنا</span>
                <h2 class="section-title">Zoho مقابل <span class="text-grad">SAP و Microsoft و Oracle والتطبيقات المحلية</span></h2>
                <p class="section-sub">لماذا تختار الشركات الصغيرة والمتوسطة وفرق mid-market في الإمارات Zoho بدلاً من عمالقة المؤسسات والأدوات المالية المحلية.</p>
            </div>
            <div class="compare-table table-responsive" data-aos="fade-up">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="text-end">الميزة</th>
                            <th class="best">Zoho Suite</th>
                            <th>SAP / MS Dynamics</th>
                            <th>Oracle NetSuite</th>
                            <th>Tally / QuickBooks</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>التطبيقات المتكاملة</td><td class="best">45+ تطبيق برخصة واحدة</td><td>وحدات بترخيص منفصل</td><td>قوية لكن معقدة</td><td>المالية فقط في الغالب</td></tr>
                        <tr><td>التخصيص</td><td class="best">Low-code (Creator) + Deluge + APIs</td><td>Power Platform / SAP BTP</td><td>يحتاج دعم شريك متعمق</td><td>تخصيص محدود</td></tr>
                        <tr><td>VAT الإماراتي والفوترة الإلكترونية</td><td class="best">5% VAT مدمج، VAT201، جاهز للفوترة الإلكترونية</td><td>عبر إضافات الشركاء</td><td>درجة مؤسسات، مكلفة</td><td>جاهز لـ VAT لكن محدود</td></tr>
                        <tr><td>WPS و EOSB</td><td class="best">إصدار رواتب الإمارات: WPS + EOSB + GPSSA</td><td>تكامل ثقيل</td><td>تخصيص مؤسسات</td><td>غالبًا يحتاج إضافات</td></tr>
                        <tr><td>واجهة عربية / RTL</td><td class="best">واجهة عربية كاملة + قوالب ثنائية</td><td>جزئي / مُعد</td><td>توطين مؤسسات</td><td>محدود</td></tr>
                        <tr><td>إجمالي التكلفة (TCO)</td><td class="best">أقل مع الاستخدام متعدد التطبيقات</td><td>تراخيص + موصلات عالية</td><td>تسعير متميز</td><td>دخول رخيص، يتوسع بشكل مكلف</td></tr>
                        <tr><td>الأنسب لـ</td><td class="best">SMB → mid-market في الإمارات</td><td>مؤسسات مرتبطة بـ MS / SAP</td><td>مؤسسات عالمية كبيرة</td><td>نشر مالي فقط</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

