    <style>
        :root {
            --c-primary: #6c5ce7;
            --c-primary-2: #00b8d9;
            --c-dark: #0b1742;
            --c-text: #1a1f3a;
            --c-muted: #5b6280;
            --c-bg: #f6f8ff;
            --grad-hero: linear-gradient(120deg, #1a1f4d 0%, #2c2466 45%, #00b8d9 100%);
            --grad-cta: linear-gradient(120deg, #6c5ce7 0%, #00b8d9 100%);
            --shadow-md: 0 10px 30px rgba(15,23,42,.08);
            --shadow-lg: 0 18px 50px rgba(15,23,42,.12);
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Cairo', 'Tajawal', system-ui, -apple-system, sans-serif;
            color: var(--c-text);
            background: #fff;
            line-height: 1.7;
            margin: 0;
            text-align: right;
            -webkit-font-smoothing: antialiased;
        }
        h1, h2, h3, h4, h5 { font-weight: 800; color: var(--c-dark); }
        a { text-decoration: none; }
        img { max-width: 100%; height: auto; }
        .text-grad { background: var(--grad-cta); -webkit-background-clip: text; background-clip: text; color: transparent; }

        /* Header */
        .top-nav { position: sticky; top: 0; z-index: 1000; background: rgba(255,255,255,.96); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); border-bottom: 1px solid rgba(15,23,42,.06); box-shadow: 0 2px 18px rgba(15,23,42,.04); }
        .top-nav .nav-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .top-nav .brand-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
        .top-nav .brand-left img { height: 40px; width: auto; flex-shrink: 0; }
        .top-nav .brand-divider { width: 1px; height: 28px; background: linear-gradient(180deg, transparent, #cbd5e1, transparent); }
        .top-nav .brand-tag { font-size: 11px; font-weight: 700; letter-spacing: .04em; color: var(--c-muted); line-height: 1.3; }
        .top-nav .nav-links { display: flex; align-items: center; gap: 4px; }
        .top-nav .nav-pill { display: inline-flex; align-items: center; gap: 8px; color: #475569; font-weight: 600; font-size: 14px; padding: 8px 14px; border-radius: 999px; transition: .2s; white-space: nowrap; }
        .top-nav .nav-pill:hover { background: rgba(108,92,231,.08); color: var(--c-primary); }
        .top-nav .partner-right { display: flex; align-items: center; gap: 10px; }
        .top-nav .partner-right img.partner-badge { height: 42px; width: auto; }

        .lang-switch { position: relative; }
        .lang-btn { display: inline-flex; align-items: center; gap: 8px; background: #f1f5f9; border: 1px solid #e2e8f0; color: var(--c-dark); font-weight: 600; font-size: 13px; padding: 8px 14px; border-radius: 999px; cursor: pointer; }
        .lang-btn:hover { background: #e2e8f0; }
        .lang-menu { position: absolute; left: 0; top: calc(100% + 8px); background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: var(--shadow-lg); min-width: 180px; padding: 6px; z-index: 100; opacity: 0; transform: translateY(-6px); pointer-events: none; transition: .2s; }
        .lang-switch.open .lang-menu { opacity: 1; transform: translateY(0); pointer-events: auto; }
        .lang-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; color: var(--c-dark); font-size: 14px; font-weight: 500; }
        .lang-menu a:hover { background: #f1f5f9; }
        .lang-menu a.active { background: rgba(108,92,231,.1); color: var(--c-primary); font-weight: 700; }

        .nav-toggle { display: none; background: #f1f5f9; border: 1px solid #e2e8f0; color: var(--c-dark); font-size: 18px; width: 44px; height: 44px; border-radius: 12px; cursor: pointer; -webkit-appearance: none; appearance: none; padding: 0; }
        .nav-toggle i { font-size: 18px; pointer-events: none; }

        .mobile-menu { position: fixed; top: 0; left: 0; width: min(86vw, 340px); height: 100vh; height: 100dvh; background: #fff; box-shadow: 10px 0 40px rgba(0,0,0,.18); z-index: 2147483646; -webkit-transform: translate3d(-100%, 0, 0); transform: translate3d(-100%, 0, 0); transition: transform .3s ease; display: flex; flex-direction: column; padding: 22px; overflow-y: auto; visibility: hidden; }
        .mobile-menu.show { -webkit-transform: translate3d(0,0,0); transform: translate3d(0,0,0); visibility: visible; }
        .mobile-overlay { position: fixed; inset: 0; background: rgba(11,23,66,.5); opacity: 0; visibility: hidden; transition: opacity .25s, visibility .25s; z-index: 2147483645; }
        .mobile-overlay.show { opacity: 1; visibility: visible; }
        .mobile-menu .mm-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid #eef0fb; margin-bottom: 8px; flex-shrink: 0; }
        .mobile-menu .mm-head img { height: 36px; max-width: 60%; }
        .mobile-menu .mm-close { background: #f1f5f9; border: 0; width: 40px; height: 40px; border-radius: 10px; color: var(--c-dark); display: flex; align-items: center; justify-content: center; flex-shrink: 0; -webkit-appearance: none; appearance: none; cursor: pointer; }
        .mobile-menu .mm-link { display: flex; align-items: center; gap: 12px; padding: 14px 12px; border-radius: 10px; color: var(--c-dark); font-weight: 600; font-size: 15px; }
        .mobile-menu .mm-link i { color: var(--c-primary); width: 20px; text-align: center; }
        .mobile-menu .mm-link:hover { background: #f6f8ff; }
        .mobile-menu .mm-divider { height: 1px; background: #eef0fb; margin: 14px 4px; }
        .mobile-menu .mm-section-title { font-size: 11px; font-weight: 700; color: var(--c-muted); padding: 8px 12px 6px; }
        .mobile-menu .mm-lang { display: flex; gap: 8px; padding: 4px 8px; }
        .mobile-menu .mm-lang a { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: 10px; background: #f6f8ff; color: var(--c-dark); font-weight: 600; font-size: 13px; border: 1px solid #eef0fb; }
        .mobile-menu .mm-lang a.active { background: rgba(108,92,231,.1); border-color: rgba(108,92,231,.3); color: var(--c-primary); }
        .mobile-menu .mm-cta { margin-top: auto; padding-top: 16px; flex-shrink: 0; }
        .mobile-menu .mm-cta-btn { display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--grad-cta); color: #fff; padding: 14px; border-radius: 12px; font-weight: 700; }
        .mobile-menu .mm-partner { display: flex; align-items: center; gap: 10px; padding: 12px; margin-top: 12px; background: #f6f8ff; border-radius: 12px; }
        .mobile-menu .mm-partner img { height: 36px; }
        .mobile-menu .mm-partner span { font-size: 12px; color: var(--c-muted); font-weight: 600; line-height: 1.3; }
        body.menu-open { overflow: hidden; position: fixed; width: 100%; }

        @media (max-width: 1099px) {
            .top-nav .partner-right img.partner-badge { height: 38px; }
            .top-nav .nav-pill { font-size: 13px; padding: 7px 11px; gap: 6px; }
            .top-nav .nav-pill i { display: none; }
        }
        @media (max-width: 991px) {
            .top-nav .nav-links, .top-nav .lang-switch, .top-nav .partner-right img.partner-badge,
            .top-nav .brand-tag, .top-nav .brand-divider { display: none !important; }
            .nav-toggle { display: inline-flex; align-items: center; justify-content: center; }
            .top-nav .brand-left img { height: 36px; }
            .top-nav .partner-right { gap: 6px; }
        }

        /* Hero */
        .hero { position: relative; background: var(--grad-hero); color: #fff; overflow: hidden; padding: 90px 0 110px; }
        .hero::before { content: ""; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=1920&q=75'); background-size: cover; background-position: center; opacity: .22; mix-blend-mode: screen; pointer-events: none; }
        .hero::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,.32) 0%, rgba(0,0,0,.18) 50%, rgba(0,0,0,.38) 100%); pointer-events: none; }
        .hero .container { position: relative; z-index: 2; }
        .hero .badge-pill { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2); color: #e6f1ff; padding: 8px 16px; border-radius: 999px; font-size: 13px; font-weight: 600; }
        .hero h1 { color: #fff; font-size: clamp(34px, 5vw, 58px); line-height: 1.15; margin: 18px 0 16px; font-weight: 800; }
        .hero .lead { color: #d6def0; font-size: 17px; max-width: 600px; }
        .hero .feature-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px; padding: 0; }
        .hero .feature-pills li { list-style: none; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); color: #eaf1ff; padding: 7px 14px; border-radius: 999px; font-size: 13px; font-weight: 500; }
        .hero .hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }
        .hero .btn-primary-x { background: linear-gradient(90deg, #00ffe1, #00b8d9); color: #0b1742; font-weight: 800; padding: 14px 28px; border-radius: 999px; transition: .2s; }
        .hero .btn-primary-x:hover { transform: translateY(-3px); }
        .hero .btn-ghost-x { background: rgba(255,255,255,.08); color: #fff; font-weight: 700; padding: 14px 28px; border-radius: 999px; border: 1px solid rgba(255,255,255,.25); transition: .2s; }
        .hero .btn-ghost-x:hover { background: rgba(255,255,255,.15); transform: translateY(-2px); color: #fff; }
        .hero .trust-row { display: flex; align-items: center; gap: 16px; margin-top: 30px; color: #cbd5e1; font-size: 14px; }
        .hero .trust-row .stars i { color: #ffd166; }

        .hero-form-card { background: rgba(255,255,255,.96); border-radius: 24px; padding: 32px; box-shadow: 0 30px 60px rgba(0,0,0,.25); color: var(--c-text); border: 1px solid rgba(255,255,255,.4); }
        .hero-form-card h3 { font-size: 22px; margin: 0 0 6px; }
        .hero-form-card .sub { color: var(--c-muted); font-size: 14px; margin: 0 0 22px; }
        .hero-form-card .form-control { border-radius: 12px; padding: 12px 16px; border: 1.5px solid #e3e8f5; background: #f9fbff; font-size: 14px; transition: .2s; text-align: right; }
        .hero-form-card .form-control:focus { border-color: var(--c-primary); background: #fff; box-shadow: 0 0 0 4px rgba(108,92,231,.12); }
        .hero-form-card .form-label { font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 6px; }
        .hero-form-card .submit-btn { background: var(--grad-cta); color: #fff; padding: 14px; border-radius: 12px; width: 100%; font-weight: 700; border: 0; box-shadow: 0 12px 25px rgba(108,92,231,.3); }
        .hero-form-card .submit-btn:hover { transform: translateY(-2px); }
        .hero-form-card .form-foot { font-size: 12px; color: var(--c-muted); text-align: center; margin-top: 14px; }
        .hero-form-card .form-foot i { color: #10b981; }

        section { position: relative; }
        .section-pad { padding: 90px 0; }
        .eyebrow { display: inline-block; font-size: 12px; font-weight: 700; color: var(--c-primary); background: rgba(108,92,231,.08); padding: 7px 14px; border-radius: 999px; }
        .section-title { font-size: clamp(28px, 3.4vw, 42px); margin: 14px 0 12px; line-height: 1.25; }
        .section-sub { color: var(--c-muted); font-size: 16px; max-width: 720px; margin: 0 auto; }

        .stats-strip { margin-top: -60px; position: relative; z-index: 5; }
        .stats-card { background: #fff; border-radius: 20px; padding: 26px; box-shadow: var(--shadow-lg); display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
        .stats-card .stat { text-align: center; border-left: 1px dashed #e2e8f0; padding: 6px 12px; }
        .stats-card .stat:last-child { border-left: 0; }
        .stats-card .num { font-size: 30px; font-weight: 800; color: var(--c-dark); line-height: 1; }
        .stats-card .lbl { font-size: 13px; color: var(--c-muted); margin-top: 6px; }
        @media (max-width: 767px) {
            .stats-card { grid-template-columns: repeat(2, 1fr); }
            .stats-card .stat:nth-child(2) { border-left: 0; }
        }

        .logos-band { background: #fff; padding: 60px 0; }
        .logos-band .marquee { display: flex; gap: 50px; align-items: center; animation: scroll 30s linear infinite; }
        .logos-band .marquee img { height: 40px; opacity: .65; filter: grayscale(1); transition: .25s; }
        .logos-band .marquee img:hover { opacity: 1; filter: grayscale(0); }
        .logos-band .marquee-wrap { overflow: hidden; mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); }
        @keyframes scroll { from { transform: translateX(0); } to { transform: translateX(50%); } }

        .feature-card { background: #fff; border: 1px solid #eef0fb; border-radius: 18px; padding: 30px; height: 100%; transition: .25s; }
        .feature-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: transparent; }
        .feature-card .icon-wrap { width: 56px; height: 56px; border-radius: 16px; display: grid; place-items: center; background: linear-gradient(135deg, #eef2ff, #e0f2fe); color: var(--c-primary); font-size: 24px; margin-bottom: 16px; }
        .feature-card h4 { font-size: 18px; margin-bottom: 8px; }
        .feature-card p { color: var(--c-muted); font-size: 14px; margin: 0; }

        .why-card { background: #fff; padding: 18px; border-radius: 14px; border: 1px solid #edf0fa; display: flex; gap: 14px; align-items: flex-start; }
        .why-card .ico { width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center; background: rgba(108,92,231,.1); color: var(--c-primary); flex-shrink: 0; }
        .why-card h5 { font-size: 16px; margin: 0 0 4px; }
        .why-card p { font-size: 14px; color: var(--c-muted); margin: 0; }

        .product-card { background: #fff; border: 1px solid #eef0fb; border-radius: 18px; padding: 22px; height: 100%; transition: .25s; display: flex; flex-direction: column; text-align: right; color: inherit; position: relative; overflow: hidden; }
        .product-card .ribbon { position: absolute; top: 12px; left: 12px; font-size: 10px; font-weight: 700; background: var(--grad-cta); color: #fff; padding: 4px 10px; border-radius: 999px; }
        .product-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: transparent; }
        .product-card .head { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
        .product-card .logo-box { width: 52px; height: 52px; border-radius: 12px; background: #f6f8ff; display: grid; place-items: center; border: 1px solid #eef0fb; padding: 8px; }
        .product-card .logo-box img { max-width: 100%; max-height: 100%; object-fit: contain; }
        .product-card h5 { font-size: 17px; margin: 0; color: var(--c-dark); }
        .product-card .meta { font-size: 12px; color: var(--c-primary); font-weight: 600; }
        .product-card p { font-size: 14px; color: var(--c-muted); margin: 0 0 14px; flex: 1; }
        .product-card .features { list-style: none; padding: 0; margin: 0 0 16px; }
        .product-card .features li { font-size: 13px; color: #4a5174; padding: 4px 0; display: flex; align-items: flex-start; gap: 8px; }
        .product-card .features i { color: #10b981; margin-top: 4px; font-size: 12px; }
        .product-card .learn { font-size: 13px; color: var(--c-primary); font-weight: 700; display: inline-flex; align-items: center; gap: 6px; margin-top: auto; }

        .compare-table { background: #fff; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-md); }
        .compare-table thead th { background: var(--c-dark); color: #fff; font-weight: 700; font-size: 13px; padding: 18px; text-align: center; border: 0; }
        .compare-table thead th.best { background: var(--grad-cta); }
        .compare-table tbody td { padding: 16px; vertical-align: middle; font-size: 14px; color: #334155; border-color: #f1f5f9; }
        .compare-table tbody td:first-child { font-weight: 700; color: var(--c-dark); background: #fafbff; }
        .compare-table tbody td.best { background: #f0f9ff; color: #0c4a6e; font-weight: 600; }

        .process-section { background: var(--c-dark); color: #fff; position: relative; overflow: hidden; }
        .process-section::before { content: ""; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1546412414-e1885259563a?auto=format&fit=crop&w=1920&q=70'); background-size: cover; opacity: .12; }
        .process-section .container { position: relative; z-index: 2; }
        .process-section .section-title, .process-section h5 { color: #fff; }
        .process-section .section-sub { color: #cbd5e1; }
        .step-card { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 18px; padding: 28px; height: 100%; transition: .25s; }
        .step-card:hover { transform: translateY(-5px); border-color: rgba(0,184,217,.5); }
        .step-card .num { font-size: 14px; font-weight: 800; color: var(--c-dark); background: linear-gradient(90deg, #00ffe1, #00b8d9); width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center; margin-bottom: 14px; }
        .step-card h5 { font-size: 18px; margin-bottom: 8px; }
        .step-card p { color: #cbd5e1; font-size: 14px; margin: 0; }

        .industry-tile { background: #fff; border: 1px solid #eef0fb; border-radius: 14px; overflow: hidden; transition: .25s; height: 100%; display: flex; flex-direction: column; text-align: center; position: relative; }
        .industry-tile:hover { border-color: var(--c-primary); box-shadow: 0 14px 32px rgba(108,92,231,.16); transform: translateY(-4px); }
        .industry-tile .ind-img { position: relative; width: 100%; height: 130px; overflow: hidden; background: linear-gradient(135deg, rgba(108,92,231,.12), rgba(0,184,217,.12)); }
        .industry-tile .ind-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .35s ease; }
        .industry-tile:hover .ind-img img { transform: scale(1.06); }
        .industry-tile .ind-img::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,.18) 100%); }
        .industry-tile .ind-icon { position: absolute; top: 10px; right: 10px; width: 34px; height: 34px; border-radius: 10px; background: rgba(255,255,255,.95); color: var(--c-primary); display: grid; place-items: center; font-size: 14px; box-shadow: 0 4px 10px rgba(0,0,0,.12); z-index: 2; }
        .industry-tile span { padding: 14px 12px; font-size: 14px; font-weight: 700; color: var(--c-dark); flex: 1; display: flex; align-items: center; justify-content: center; line-height: 1.3; }
        @media (max-width: 575px) {
            .industry-tile .ind-img { height: 100px; }
            .industry-tile .ind-icon { width: 28px; height: 28px; font-size: 12px; }
            .industry-tile span { padding: 10px 8px; font-size: 12.5px; }
        }

        .service-card { background: #fff; border: 1px solid #eef0fb; border-radius: 18px; padding: 28px; height: 100%; transition: .25s; border-top: 3px solid transparent; }
        .service-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); border-top-color: var(--c-primary); }
        .service-card .ico { width: 50px; height: 50px; border-radius: 14px; background: linear-gradient(135deg, rgba(108,92,231,.1), rgba(0,184,217,.1)); color: var(--c-primary); display: grid; place-items: center; font-size: 20px; margin-bottom: 16px; }
        .service-card h5 { font-size: 18px; margin-bottom: 8px; }
        .service-card p { color: var(--c-muted); font-size: 14px; margin: 0; }

        .testi-card { background: #fff; border-radius: 20px; padding: 30px; box-shadow: var(--shadow-md); height: 100%; position: relative; border: 1px solid #eef0fb; }
        .testi-card::before { content: '\201C'; position: absolute; top: 10px; left: 24px; font-size: 80px; line-height: 1; color: var(--c-primary); opacity: .12; font-family: Georgia, serif; }
        .testi-card .stars { color: #ffd166; margin-bottom: 14px; }
        .testi-card .quote { font-size: 15px; color: #334155; line-height: 1.85; margin-bottom: 22px; }
        .testi-card .who { display: flex; align-items: center; gap: 14px; }
        .testi-card .avatar { width: 48px; height: 48px; border-radius: 50%; background: var(--grad-cta); color: #fff; display: grid; place-items: center; font-weight: 800; }
        .testi-card .name { font-weight: 700; color: var(--c-dark); }
        .testi-card .role { font-size: 13px; color: var(--c-muted); }

        .faq-item { background: var(--c-bg); border: 1px solid #eef0fb; border-radius: 14px; margin-bottom: 14px; overflow: hidden; transition: .2s; }
        .faq-item.open { background: #fff; border-color: var(--c-primary); box-shadow: var(--shadow-md); }
        .faq-item .q { width: 100%; background: transparent; border: 0; padding: 20px 24px; text-align: right; font-weight: 700; color: var(--c-dark); font-size: 15px; display: flex; justify-content: space-between; align-items: center; gap: 14px; cursor: pointer; }
        .faq-item .q i { transition: .25s; color: var(--c-primary); flex-shrink: 0; }
        .faq-item.open .q i { transform: rotate(45deg); }
        .faq-item .a { padding: 0 24px; max-height: 0; overflow: hidden; transition: max-height .25s, padding .25s; }
        .faq-item.open .a { padding: 0 24px 22px; max-height: 600px; }
        .faq-item .a p { color: #475569; font-size: 14.5px; margin: 0; line-height: 1.85; }

        .final-cta { background: var(--grad-hero); color: #fff; padding: 90px 0; position: relative; overflow: hidden; }
        .final-cta::before { content: ""; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1518684079-3c830dcef090?auto=format&fit=crop&w=1920&q=70'); background-size: cover; background-position: center; opacity: .15; mix-blend-mode: overlay; }
        .final-cta .container { position: relative; z-index: 2; }
        .final-cta h2 { color: #fff; font-size: clamp(28px, 4vw, 48px); }
        .final-cta p { color: #d6def0; font-size: 17px; max-width: 720px; margin: 14px auto 28px; }
        .final-cta .btn-primary-x { background: linear-gradient(90deg, #00ffe1, #00b8d9); color: #0b1742; font-weight: 800; padding: 16px 34px; border-radius: 999px; display: inline-flex; gap: 10px; align-items: center; }

        footer { background: #060c25; color: #cbd5e1; padding: 70px 0 0; }
        footer h6 { color: #fff; font-weight: 700; margin-bottom: 16px; font-size: 15px; }
        footer p, footer a, footer li { font-size: 14px; line-height: 1.85; }
        footer a { color: #cbd5e1; }
        footer a:hover { color: #00ffe1; }
        footer ul { list-style: none; padding: 0; margin: 0; }
        footer .socials a { width: 38px; height: 38px; border-radius: 10px; display: inline-grid; place-items: center; background: rgba(255,255,255,.06); color: #cbd5e1; transition: .2s; margin-left: 8px; }
        footer .socials a:hover { background: var(--grad-cta); color: #fff; }
        footer .bot { border-top: 1px solid rgba(255,255,255,.08); margin-top: 50px; padding: 22px 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-size: 13px; }
        footer .bot .emp { color: #00ffe1; }

        .office-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 8px; }
        .office-card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px; display: flex; gap: 12px; transition: .2s; }
        .office-card:hover { background: rgba(255,255,255,.07); border-color: rgba(0,255,225,.3); }
        .office-flag { font-size: 26px; width: 40px; height: 40px; display: grid; place-items: center; background: rgba(255,255,255,.06); border-radius: 10px; flex-shrink: 0; }
        .office-body { flex: 1; min-width: 0; }
        .office-title { color: #fff; font-weight: 700; font-size: 14px; margin-bottom: 6px; }
        .office-line { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: #cbd5e1; line-height: 1.55; margin-bottom: 4px; text-decoration: none; }
        .office-line i { color: #00ffe1; font-size: 13px; margin-top: 3px; flex-shrink: 0; }
        a.office-line:hover { color: #00ffe1; }

        @media (max-width: 575px) { .office-grid { grid-template-columns: 1fr; } }

        /* WhatsApp — moved to right side for RTL */
        .wa-float { position: fixed; right: 20px; bottom: 24px; z-index: 9999; width: 60px; height: 60px; border-radius: 50%; background: #25D366; color: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 22px rgba(37,211,102,.5); animation: wa-pulse 2s ease-in-out infinite; }
        .wa-float:hover { color: #fff; transform: scale(1.08); }
        @keyframes wa-pulse { 0%,100% { box-shadow: 0 6px 22px rgba(37,211,102,.5); } 50% { box-shadow: 0 6px 28px rgba(37,211,102,.65), 0 0 0 14px rgba(37,211,102,.12); } }
        @media (max-width: 575px) { .wa-float { width: 52px; height: 52px; right: 14px; bottom: 18px; } .wa-float i { font-size: 24px !important; } }

        @media (max-width: 1199px) { .section-pad { padding: 70px 0; } }
        @media (max-width: 991px) {
            .hero { padding: 56px 0 80px; }
            .hero h1 { font-size: 36px !important; }
            .hero .lead { font-size: 15px; }
            .hero-form-card { margin-top: 30px; padding: 26px; }
            .stats-strip { margin-top: -34px; }
            .section-pad { padding: 60px 0; }
            .section-title { font-size: 28px !important; }
        }
        @media (max-width: 767px) {
            .hero { padding: 40px 0 70px; }
            .hero h1 { font-size: 30px !important; }
            .section-pad { padding: 50px 0; }
            .section-title { font-size: 24px !important; }
            .feature-card, .service-card, .step-card, .testi-card { padding: 22px; }
            .product-card { padding: 18px; }
            .compare-table thead th, .compare-table tbody td { font-size: 12px; padding: 10px 8px; }
            .faq-item .q { font-size: 14px; padding: 16px 18px; }
            .faq-item .a { padding: 0 18px; }
            .faq-item.open .a { padding: 0 18px 18px; }
            footer { padding-top: 50px; }
            footer .bot { flex-direction: column; align-items: flex-start; gap: 6px; }
        }
        @media (max-width: 575px) {
            html, body { overflow-x: hidden; }
            .hero h1 { font-size: 26px !important; }
            .hero .hero-ctas { flex-direction: column; }
            .hero .btn-primary-x, .hero .btn-ghost-x { width: 100%; justify-content: center; display: flex; }
            .hero-form-card { padding: 20px; }
            .hero-form-card .col-6 { flex: 0 0 100%; max-width: 100%; }
            .section-title { font-size: 22px !important; }
        }

        /* ========= Auto-open lead modal (RTL) ========= */
        .rq-modal-overlay { position: fixed; inset: 0; background: rgba(11,23,66,.55); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 2147483640; opacity: 0; visibility: hidden; transition: opacity .3s ease, visibility .3s ease; }
        .rq-modal-overlay.show { opacity: 1; visibility: visible; }
        .rq-modal { position: fixed; top: 50%; left: 50%; -webkit-transform: translate(-50%, -45%) scale(.96); transform: translate(-50%, -45%) scale(.96); width: min(94vw, 960px); max-height: 88vh; background: #fff; border-radius: 24px; box-shadow: 0 30px 80px rgba(0,0,0,.4); z-index: 2147483641; opacity: 0; visibility: hidden; transition: opacity .35s ease, transform .35s cubic-bezier(.2,1.05,.4,1.05), visibility .35s ease; overflow: hidden; }
        .rq-modal.show { opacity: 1; visibility: visible; -webkit-transform: translate(-50%, -50%) scale(1); transform: translate(-50%, -50%) scale(1); }
        .rq-grid { display: grid; grid-template-columns: 1.05fr 1fr; max-height: 88vh; }
        .rq-left { background: linear-gradient(160deg, #eef3ff 0%, #fff 100%); padding: 30px 28px; overflow-y: auto; }
        .rq-right { padding: 30px 28px; overflow-y: auto; position: relative; }
        .rq-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .04em; color: #4f46e5; background: rgba(79,70,229,.08); padding: 7px 14px; border-radius: 999px; margin-bottom: 14px; }
        .rq-left h2 { font-size: 24px; font-weight: 800; color: #0b1742; line-height: 1.4; margin: 0 0 20px; }
        .rq-flags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
        .rq-flags span { background: #fff; border: 1px solid #e2e8f0; border-radius: 999px; padding: 6px 12px; font-size: 13px; font-weight: 600; color: #1a1f3a; display: inline-flex; align-items: center; gap: 6px; box-shadow: 0 2px 6px rgba(0,0,0,.03); }
        .rq-testimonial { background: #fff; border-radius: 14px; padding: 20px; box-shadow: 0 4px 16px rgba(0,0,0,.04); color: #334155; font-size: 14px; line-height: 1.85; margin-bottom: 14px; border: 1px solid #eef0fb; }
        .rq-author { display: flex; align-items: center; gap: 12px; padding: 4px 4px 18px; }
        .rq-avatar { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #f97316, #ef4444); color: #fff; display: grid; place-items: center; font-weight: 800; font-size: 14px; flex-shrink: 0; }
        .rq-name { font-weight: 700; color: #0b1742; font-size: 14px; }
        .rq-role { font-size: 12px; color: #64748b; margin-top: 2px; }
        .rq-clients-title { font-size: 11px; font-weight: 700; color: #64748b; margin: 12px 0 12px; }
        .rq-clients-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
        .rq-client { background: #fff; border: 1px solid #eef0fb; border-radius: 10px; padding: 10px 8px; display: flex; align-items: center; justify-content: center; transition: .2s; min-height: 64px; }
        .rq-client:hover { border-color: #6c5ce7; transform: translateY(-2px); }
        .rq-client img { max-width: 100%; max-height: 32px; object-fit: contain; }
        .rq-partner-badges { display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid #eef0fb; border-radius: 16px; padding: 10px 14px; margin-bottom: 22px; width: fit-content; }
        .rq-partner-badges img.zoho-logo { height: 30px; }
        .rq-partner-badges img.auth-badge { height: 44px; }
        .rq-right h3 { font-size: 22px; font-weight: 800; color: #0b1742; margin: 0 0 6px; }
        .rq-right .rq-sub { color: #64748b; font-size: 14px; margin: 0 0 22px; }
        .rq-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
        .rq-field { display: flex; flex-direction: column; }
        .rq-field label { font-size: 13px; font-weight: 600; color: #1a1f3a; margin-bottom: 6px; text-align: right; }
        .rq-field label .req { color: #ef4444; }
        .rq-field input, .rq-field select, .rq-field textarea { border: 1.5px solid #e3e8f5; border-radius: 12px; padding: 11px 14px; background: #fff; font-size: 14px; color: #1a1f3a; font-family: inherit; transition: .2s; width: 100%; -webkit-appearance: none; appearance: none; text-align: right; }
        .rq-field select { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2364748b' stroke-width='2' stroke-linecap='round'><polyline points='6 9 12 15 18 9'/></svg>"); background-repeat: no-repeat; background-position: left 12px center; background-size: 16px; padding-left: 36px; }
        .rq-field input:focus, .rq-field select:focus, .rq-field textarea:focus { border-color: #6c5ce7; outline: none; box-shadow: 0 0 0 4px rgba(108,92,231,.12); }
        .rq-field textarea { min-height: 90px; resize: vertical; line-height: 1.7; }
        .rq-note { font-size: 12px; color: #64748b; margin: 12px 0 14px; line-height: 1.7; }
        .rq-note a { color: #4f46e5; font-weight: 600; }
        .rq-submit { background: linear-gradient(120deg, #2563eb, #4f46e5); color: #fff; border: 0; border-radius: 999px; padding: 14px; width: 100%; font-weight: 700; font-size: 15px; cursor: pointer; transition: .2s; box-shadow: 0 12px 25px rgba(37,99,235,.25); font-family: inherit; }
        .rq-submit:hover { transform: translateY(-2px); }
        .rq-close { position: absolute; top: 14px; left: 14px; width: 36px; height: 36px; border-radius: 50%; background: rgba(11,23,66,.06); border: 0; color: #1a1f3a; font-size: 18px; cursor: pointer; z-index: 10; transition: .2s; display: grid; place-items: center; }
        .rq-close:hover { background: rgba(11,23,66,.12); transform: rotate(90deg); }
        .rq-success { background: #dcfce7; color: #065f46; border: 1px solid #bbf7d0; padding: 14px; border-radius: 12px; font-size: 14px; margin-top: 12px; display: none; text-align: right; }
        .rq-success.show { display: block; }
        body.rq-modal-open { overflow: hidden; }
        @media (max-width: 880px) {
            .rq-grid { grid-template-columns: 1fr; max-height: 100vh; }
            .rq-left { display: none; }
            .rq-modal { max-height: 96vh; width: 96vw; border-radius: 18px; }
            .rq-right { padding: 22px 18px 18px; max-height: 96vh; }
            .rq-right h3 { font-size: 18px; margin-bottom: 4px; }
            .rq-right .rq-sub { font-size: 13px; margin-bottom: 14px; }
            .rq-row { grid-template-columns: 1fr; gap: 8px; margin-bottom: 8px; }
            .rq-field label { font-size: 12.5px; margin-bottom: 4px; }
            .rq-field input, .rq-field select, .rq-field textarea { padding: 10px 12px; font-size: 13.5px; }
            .rq-close { background: #f1f5f9; top: 10px; left: 10px; }
            .rq-partner-badges { padding: 6px 10px; margin-bottom: 14px; }
            .rq-partner-badges img.zoho-logo { height: 22px; }
            .rq-partner-badges img.auth-badge { height: 32px; }
            .rq-submit { padding: 12px; font-size: 14px; margin-top: 6px; }
            .rq-hide-mobile { display: none !important; }
        }
    </style>
</head>

<body>

    <!-- Header -->
    <nav class="top-nav py-3">
