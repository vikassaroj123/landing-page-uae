    <style>
        :root {
            --c-primary: #6c5ce7;
            --c-primary-2: #00b8d9;
            --c-accent: #ff6b6b;
            --c-dark: #0b1742;
            --c-text: #1a1f3a;
            --c-muted: #5b6280;
            --c-bg: #f6f8ff;
            --grad-hero: linear-gradient(120deg, #1a1f4d 0%, #2c2466 45%, #00b8d9 100%);
            --grad-cta: linear-gradient(120deg, #6c5ce7 0%, #00b8d9 100%);
            --grad-soft: linear-gradient(180deg, #ffffff 0%, #f6f8ff 100%);
            --shadow-md: 0 10px 30px rgba(15, 23, 42, .08);
            --shadow-lg: 0 18px 50px rgba(15, 23, 42, .12);
            --radius: 18px;
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Plus Jakarta Sans', 'Inter', system-ui, -apple-system, sans-serif;
            color: var(--c-text);
            background: #fff;
            line-height: 1.65;
            margin: 0;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            text-rendering: optimizeLegibility;
        }
        /* All scroll-reveal elements visible immediately (AOS disabled) */
        [data-aos] { opacity: 1 !important; transform: none !important; transition: none !important; }
        ::selection { background: rgba(108, 92, 231, .18); color: var(--c-dark); }
        h1, h2, h3, h4, h5 { font-weight: 800; letter-spacing: -.02em; color: var(--c-dark); }
        a { text-decoration: none; }
        img { max-width: 100%; height: auto; }
        .text-grad { background: var(--grad-cta); -webkit-background-clip: text; background-clip: text; color: transparent; }

        /* ========= Header ========= */
        .top-nav {
            position: sticky; top: 0; z-index: 1000;
            background: rgba(255, 255, 255, .96);
            backdrop-filter: saturate(180%) blur(14px);
            -webkit-backdrop-filter: saturate(180%) blur(14px);
            border-bottom: 1px solid rgba(15, 23, 42, .06);
            box-shadow: 0 2px 18px rgba(15, 23, 42, .04);
        }
        .top-nav .nav-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .top-nav .brand-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
        .top-nav .brand-left img { height: 48px; width: auto; flex-shrink: 0; }
        .top-nav .brand-divider { width: 1px; height: 28px; background: linear-gradient(180deg, transparent, #cbd5e1, transparent); }
        .top-nav .brand-tag { font-size: 11px; font-weight: 700; letter-spacing: .08em; color: var(--c-muted); text-transform: uppercase; line-height: 1.2; }
        .top-nav .nav-links { display: flex; align-items: center; gap: 4px; }
        .top-nav .nav-pill { display: inline-flex; align-items: center; gap: 8px; color: #475569; font-weight: 600; font-size: 14px; padding: 8px 14px; border-radius: 999px; transition: background .2s ease, color .2s ease, transform .2s ease; white-space: nowrap; }
        .top-nav .nav-pill:hover { background: rgba(108, 92, 231, .08); color: var(--c-primary); transform: translateY(-1px); }
        .top-nav .partner-right { display: flex; align-items: center; gap: 10px; }
        .top-nav .partner-right img.partner-badge { height: 42px; width: auto; }

        /* Language selector */
        .lang-switch { position: relative; }
        .lang-btn {
            display: inline-flex; align-items: center; gap: 8px;
            background: #f1f5f9; border: 1px solid #e2e8f0;
            color: var(--c-dark); font-weight: 600; font-size: 13px;
            padding: 8px 14px; border-radius: 999px; cursor: pointer;
            transition: .2s;
        }
        .lang-btn:hover { background: #e2e8f0; }
        .lang-btn .flag { font-size: 16px; line-height: 1; }
        .lang-btn .caret { font-size: 10px; opacity: .6; }
        .lang-menu {
            position: absolute; right: 0; top: calc(100% + 8px);
            background: #fff; border: 1px solid #e2e8f0;
            border-radius: 12px; box-shadow: var(--shadow-lg);
            min-width: 180px; padding: 6px; z-index: 100;
            opacity: 0; transform: translateY(-6px); pointer-events: none;
            transition: .2s;
        }
        .lang-switch.open .lang-menu { opacity: 1; transform: translateY(0); pointer-events: auto; }
        .lang-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; color: var(--c-dark); font-size: 14px; font-weight: 500; }
        .lang-menu a:hover { background: #f1f5f9; }
        .lang-menu a.active { background: rgba(108, 92, 231, .1); color: var(--c-primary); font-weight: 700; }
        .lang-menu a .flag { font-size: 18px; }

        /* Hamburger */
        .nav-toggle {
            display: none; background: #f1f5f9; border: 1px solid #e2e8f0;
            color: var(--c-dark); font-size: 18px;
            width: 44px; height: 44px; border-radius: 12px;
            cursor: pointer; transition: background .2s;
            -webkit-tap-highlight-color: transparent;
            -webkit-appearance: none; appearance: none;
            padding: 0; line-height: 1;
        }
        .nav-toggle:hover, .nav-toggle:active { background: #e2e8f0; }
        .nav-toggle i { font-size: 18px; color: var(--c-dark); pointer-events: none; }

        /* Mobile drawer */
        .mobile-menu {
            position: fixed; top: 0; right: 0;
            width: min(86vw, 340px);
            height: 100vh; height: 100dvh;
            background: #fff;
            box-shadow: -10px 0 40px rgba(0,0,0,.18);
            z-index: 2147483646;
            -webkit-transform: translate3d(100%, 0, 0); transform: translate3d(100%, 0, 0);
            -webkit-transition: -webkit-transform .3s ease; transition: transform .3s ease;
            display: flex; flex-direction: column; padding: 22px;
            overflow-y: auto; -webkit-overflow-scrolling: touch;
            visibility: hidden;
        }
        .mobile-menu.show { -webkit-transform: translate3d(0,0,0); transform: translate3d(0,0,0); visibility: visible; }
        .mobile-overlay {
            position: fixed; inset: 0;
            background: rgba(11,23,66,.5);
            opacity: 0; visibility: hidden;
            transition: opacity .25s ease, visibility .25s ease;
            z-index: 2147483645;
        }
        .mobile-overlay.show { opacity: 1; visibility: visible; }
        .mobile-menu .mm-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid #eef0fb; margin-bottom: 8px; flex-shrink: 0; }
        .mobile-menu .mm-head img { height: 36px; max-width: 60%; object-fit: contain; }
        .mobile-menu .mm-close { background: #f1f5f9; border: 0; width: 40px; height: 40px; border-radius: 10px; color: var(--c-dark); font-size: 16px; cursor: pointer; -webkit-appearance: none; appearance: none; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .mobile-menu .mm-link { display: flex; align-items: center; gap: 12px; padding: 14px 12px; border-radius: 10px; color: var(--c-dark); font-weight: 600; font-size: 15px; text-decoration: none; transition: background .15s; }
        .mobile-menu .mm-link i { color: var(--c-primary); width: 20px; text-align: center; }
        .mobile-menu .mm-link:hover, .mobile-menu .mm-link:active { background: #f6f8ff; }
        .mobile-menu .mm-divider { height: 1px; background: #eef0fb; margin: 14px 4px; }
        .mobile-menu .mm-section-title { font-size: 11px; font-weight: 700; color: var(--c-muted); text-transform: uppercase; letter-spacing: .1em; padding: 8px 12px 6px; }
        .mobile-menu .mm-lang { display: flex; gap: 8px; padding: 4px 8px; }
        .mobile-menu .mm-lang a { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: 10px; background: #f6f8ff; color: var(--c-dark); font-weight: 600; font-size: 13px; border: 1px solid #eef0fb; text-decoration: none; }
        .mobile-menu .mm-lang a.active { background: rgba(108,92,231,.1); border-color: rgba(108,92,231,.3); color: var(--c-primary); }
        .mobile-menu .mm-cta { margin-top: auto; padding-top: 16px; flex-shrink: 0; }
        .mobile-menu .mm-cta-btn { display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--grad-cta); color: #fff; padding: 14px; border-radius: 12px; font-weight: 700; box-shadow: 0 12px 25px rgba(108,92,231,.3); text-decoration: none; }
        .mobile-menu .mm-partner { display: flex; align-items: center; gap: 10px; padding: 12px; margin-top: 12px; background: #f6f8ff; border-radius: 12px; text-decoration: none; }
        .mobile-menu .mm-partner img { height: 36px; }
        .mobile-menu .mm-partner span { font-size: 12px; color: var(--c-muted); font-weight: 600; line-height: 1.3; }
        body.menu-open { overflow: hidden; position: fixed; width: 100%; }

        @media (max-width: 1099px) {
            .top-nav .partner-right img.partner-badge { height: 38px; }
            .top-nav .nav-pill { font-size: 13px; padding: 7px 11px; gap: 6px; }
            .top-nav .nav-pill i { display: none; }
        }
        @media (max-width: 991px) {
            .top-nav .nav-links, .top-nav .lang-switch, .top-nav .partner-right img.partner-badge,
            .top-nav .brand-tag, .top-nav .brand-divider { display: none !important; }
            .nav-toggle { display: inline-flex; align-items: center; justify-content: center; }
            .top-nav .brand-left img { height: 42px; }
            .top-nav .partner-right { gap: 6px; }
        }
        @media (max-width: 360px) {
            .top-nav .brand-left img { height: 36px; }
            .nav-toggle { width: 40px; height: 40px; }
        }

        /* ========= Hero ========= */
        .hero {
            position: relative;
            background: var(--grad-hero);
            color: #fff;
            overflow: hidden;
            padding: 90px 0 110px;
        }
        .hero::before {
            content: ""; position: absolute; inset: 0;
            background-image: url('https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=1920&q=75');
            background-size: cover; background-position: center;
            opacity: 0.22; mix-blend-mode: screen; pointer-events: none;
        }
        .hero::after {
            content: ""; position: absolute; inset: 0;
            background: linear-gradient(180deg, rgba(0,0,0,.32) 0%, rgba(0,0,0,.18) 50%, rgba(0,0,0,.38) 100%);
            pointer-events: none;
        }
        .hero .container { position: relative; z-index: 2; }
        .hero .badge-pill {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(255, 255, 255, .12);
            border: 1px solid rgba(255, 255, 255, .25);
            color: #e6f1ff; padding: 8px 16px;
            border-radius: 999px; font-size: 13px; font-weight: 600;
            backdrop-filter: blur(12px);
            box-shadow: 0 4px 18px rgba(0,0,0,.12);
        }
        .hero .badge-pill .dot { width: 7px; height: 7px; border-radius: 50%; background: #00ffe1; box-shadow: 0 0 0 4px rgba(0,255,225,.18); }
        .hero h1 { color: #fff; font-size: clamp(34px, 5vw, 60px); line-height: 1.05; margin: 18px 0 16px; font-weight: 800; }
        .hero .lead { color: #d6def0; font-size: 17px; max-width: 600px; }
        .hero .feature-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 22px; padding: 0; }
        .hero .feature-pills li { list-style: none; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); color: #eaf1ff; padding: 7px 14px; border-radius: 999px; font-size: 13px; font-weight: 500; backdrop-filter: blur(8px); }
        .hero .hero-ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }
        .hero .btn-primary-x { background: linear-gradient(90deg, #00ffe1, #00b8d9); color: #0b1742; font-weight: 800; padding: 14px 28px; border-radius: 999px; border: 0; box-shadow: 0 14px 30px rgba(0,255,225,.25); transition: transform .2s ease, box-shadow .2s ease; }
        .hero .btn-primary-x:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(0,255,225,.4); }
        .hero .btn-ghost-x { background: rgba(255,255,255,.08); color: #fff; font-weight: 700; padding: 14px 28px; border-radius: 999px; border: 1px solid rgba(255,255,255,.25); transition: background .2s ease, transform .2s ease, border-color .2s ease; }
        .hero .btn-ghost-x:hover { background: rgba(255,255,255,.15); transform: translateY(-2px); color: #fff; border-color: rgba(255,255,255,.4); }
        .hero .trust-row { display: flex; align-items: center; gap: 16px; margin-top: 30px; color: #cbd5e1; font-size: 14px; }
        .hero .trust-row .stars i { color: #ffd166; }

        .hero-form-card {
            background: rgba(255,255,255,.96);
            border-radius: 24px; padding: 32px;
            box-shadow: 0 30px 60px rgba(0,0,0,.25);
            color: var(--c-text);
            border: 1px solid rgba(255,255,255,.4);
        }
        .hero-form-card h3 { font-size: 22px; margin: 0 0 6px; }
        .hero-form-card .sub { color: var(--c-muted); font-size: 14px; margin: 0 0 22px; }
        .hero-form-card .form-control { border-radius: 12px; padding: 12px 16px; border: 1.5px solid #e3e8f5; background: #f9fbff; font-size: 14px; transition: .2s; }
        .hero-form-card .form-control:focus { border-color: var(--c-primary); background: #fff; box-shadow: 0 0 0 4px rgba(108,92,231,.12); }
        .hero-form-card .form-label { font-size: 13px; font-weight: 600; color: #334155; margin-bottom: 6px; }
        .hero-form-card .submit-btn { background: var(--grad-cta); color: #fff; padding: 14px; border-radius: 12px; width: 100%; font-weight: 700; border: 0; transition: transform .2s ease, box-shadow .2s ease; box-shadow: 0 12px 25px rgba(108,92,231,.3); }
        .hero-form-card .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 18px 35px rgba(108,92,231,.42); }
        .hero-form-card .form-foot { font-size: 12px; color: var(--c-muted); text-align: center; margin-top: 14px; }
        .hero-form-card .form-foot i { color: #10b981; }

        section { position: relative; }
        .section-pad { padding: 90px 0; }
        .eyebrow { display: inline-block; font-size: 12px; font-weight: 700; letter-spacing: .14em; color: var(--c-primary); text-transform: uppercase; background: linear-gradient(135deg, rgba(108,92,231,.1), rgba(0,184,217,.08)); padding: 8px 16px; border-radius: 999px; border: 1px solid rgba(108,92,231,.12); }
        .section-title { font-size: clamp(28px, 3.4vw, 42px); margin: 16px 0 14px; line-height: 1.15; }
        .section-sub { color: var(--c-muted); font-size: 16px; max-width: 720px; margin: 0 auto; line-height: 1.7; }

        .stats-strip { margin-top: -60px; position: relative; z-index: 5; }
        .stats-card { background: #fff; border-radius: 22px; padding: 28px; box-shadow: 0 22px 60px rgba(15,23,42,.14); display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; border: 1px solid rgba(108,92,231,.06); }
        .stats-card .stat { text-align: center; border-right: 1px dashed #e2e8f0; padding: 6px 12px; transition: transform .25s ease; }
        .stats-card .stat:hover { transform: translateY(-3px); }
        .stats-card .stat:last-child { border-right: 0; }
        .stats-card .num { font-size: 32px; font-weight: 800; background: var(--grad-cta); -webkit-background-clip: text; background-clip: text; color: transparent; line-height: 1; }
        .stats-card .lbl { font-size: 13px; color: var(--c-muted); margin-top: 8px; font-weight: 500; }
        @media (max-width: 767px) {
            .stats-card { grid-template-columns: repeat(2, 1fr); }
            .stats-card .stat:nth-child(2) { border-right: 0; }
        }

        .logos-band { background: #fff; padding: 60px 0; }
        .logos-band .marquee { display: flex; gap: 50px; align-items: center; animation: scroll 30s linear infinite; }
        .logos-band .marquee img { height: 40px; opacity: .65; filter: grayscale(1); transition: .25s; }
        .logos-band .marquee img:hover { opacity: 1; filter: grayscale(0); }
        .logos-band .marquee-wrap { overflow: hidden; mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); }
        @keyframes scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

        .feature-card { background: #fff; border: 1px solid #eef0fb; border-radius: var(--radius); padding: 30px; height: 100%; transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease; position: relative; overflow: hidden; }
        .feature-card::after { content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1px; background: linear-gradient(135deg, rgba(108,92,231,.0), rgba(0,184,217,.0)); -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none; transition: background .28s ease; }
        .feature-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: transparent; }
        .feature-card:hover::after { background: linear-gradient(135deg, rgba(108,92,231,.5), rgba(0,184,217,.5)); }
        .feature-card .icon-wrap { width: 56px; height: 56px; border-radius: 16px; display: grid; place-items: center; background: linear-gradient(135deg, #eef2ff, #e0f2fe); color: var(--c-primary); font-size: 24px; margin-bottom: 16px; }
        .feature-card h4 { font-size: 18px; margin-bottom: 8px; }
        .feature-card p { color: var(--c-muted); font-size: 14px; margin: 0; }

        .why-section { background: #fff; }
        .why-card { background: #fff; padding: 20px; border-radius: 14px; border: 1px solid #edf0fa; display: flex; gap: 14px; align-items: flex-start; transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; }
        .why-card:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(15,23,42,.07); border-color: rgba(108,92,231,.18); }
        .why-card .ico { width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center; background: linear-gradient(135deg, rgba(108,92,231,.12), rgba(0,184,217,.12)); color: var(--c-primary); flex-shrink: 0; }
        .why-card h5 { font-size: 16px; margin: 0 0 4px; }
        .why-card p { font-size: 14px; color: var(--c-muted); margin: 0; }

        .products-section { background: #fff; }
        .product-card { background: #fff; border: 1px solid #eef0fb; border-radius: 18px; padding: 22px; height: 100%; transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease; display: flex; flex-direction: column; text-align: left; color: inherit; position: relative; overflow: hidden; }
        .product-card .ribbon { position: absolute; top: 12px; right: 12px; font-size: 10px; font-weight: 700; letter-spacing: .08em; background: var(--grad-cta); color: #fff; padding: 4px 10px; border-radius: 999px; text-transform: uppercase; box-shadow: 0 6px 16px rgba(108,92,231,.28); }
        .product-card:hover { transform: translateY(-5px); box-shadow: 0 22px 50px rgba(15,23,42,.12); border-color: rgba(108,92,231,.18); }
        .product-card .learn { transition: gap .25s ease; }
        .product-card .learn i { transition: transform .25s ease; }
        .product-card .head { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
        .product-card .logo-box { width: 52px; height: 52px; border-radius: 12px; background: #f6f8ff; display: grid; place-items: center; border: 1px solid #eef0fb; padding: 8px; }
        .product-card .logo-box img { max-width: 100%; max-height: 100%; object-fit: contain; }
        .product-card h5 { font-size: 17px; margin: 0; color: var(--c-dark); }
        .product-card .meta { font-size: 12px; color: var(--c-primary); font-weight: 600; }
        .product-card p { font-size: 14px; color: var(--c-muted); margin: 0 0 14px; flex: 1; }
        .product-card .features { list-style: none; padding: 0; margin: 0 0 16px; }
        .product-card .features li { font-size: 13px; color: #4a5174; padding: 4px 0; display: flex; align-items: flex-start; gap: 8px; }
        .product-card .features i { color: #10b981; margin-top: 4px; font-size: 12px; }
        .product-card .learn { font-size: 13px; color: var(--c-primary); font-weight: 700; display: inline-flex; align-items: center; gap: 6px; margin-top: auto; }
        .product-card:hover .learn i { transform: translateX(4px); }

        .compare-section { background: #fff; }
        .compare-table { background: #fff; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-md); }
        .compare-table table { margin: 0; }
        .compare-table thead th { background: var(--c-dark); color: #fff; font-weight: 700; font-size: 13px; padding: 18px; text-align: center; border: 0; }
        .compare-table thead th.best { background: var(--grad-cta); }
        .compare-table tbody td { padding: 16px; vertical-align: middle; font-size: 14px; color: #334155; border-color: #f1f5f9; }
        .compare-table tbody td:first-child { font-weight: 700; color: var(--c-dark); background: #fafbff; }
        .compare-table tbody td.best { background: #f0f9ff; color: #0c4a6e; font-weight: 600; }

        .process-section { background: var(--c-dark); color: #fff; position: relative; overflow: hidden; }
        .process-section::before { content: ""; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1546412414-e1885259563a?auto=format&fit=crop&w=1920&q=70'); background-size: cover; background-position: center; opacity: .12; }
        .process-section::after { content: ""; position: absolute; inset: 0; background: radial-gradient(700px 400px at 80% 30%, rgba(0,184,217,.25), transparent 70%); }
        .process-section .container { position: relative; z-index: 2; }
        .process-section .section-title, .process-section h5 { color: #fff; }
        .process-section .section-sub { color: #cbd5e1; }
        .step-card { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 18px; padding: 28px; backdrop-filter: blur(10px); height: 100%; transition: .25s; }
        .step-card:hover { transform: translateY(-5px); border-color: rgba(0,184,217,.5); }
        .step-card .num { font-size: 14px; font-weight: 800; color: var(--c-dark); background: linear-gradient(90deg, #00ffe1, #00b8d9); width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center; margin-bottom: 14px; }
        .step-card h5 { font-size: 18px; margin-bottom: 8px; }
        .step-card p { color: #cbd5e1; font-size: 14px; margin: 0; }

        .industries-section { background: #fff; }
        .industry-tile { background: #fff; border: 1px solid #eef0fb; border-radius: 14px; overflow: hidden; transition: .25s; height: 100%; display: flex; flex-direction: column; text-align: center; position: relative; }
        .industry-tile:hover { border-color: var(--c-primary); box-shadow: 0 14px 32px rgba(108,92,231,.16); transform: translateY(-4px); }
        .industry-tile .ind-img { position: relative; width: 100%; height: 130px; overflow: hidden; background: linear-gradient(135deg, rgba(108,92,231,.12), rgba(0,184,217,.12)); }
        .industry-tile .ind-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .35s ease; }
        .industry-tile:hover .ind-img img { transform: scale(1.06); }
        .industry-tile .ind-img::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,.18) 100%); }
        .industry-tile .ind-icon { position: absolute; top: 10px; right: 10px; width: 34px; height: 34px; border-radius: 10px; background: rgba(255,255,255,.95); color: var(--c-primary); display: grid; place-items: center; font-size: 14px; box-shadow: 0 4px 10px rgba(0,0,0,.12); z-index: 2; }
        .industry-tile span { padding: 14px 12px; font-size: 14px; font-weight: 700; color: var(--c-dark); flex: 1; display: flex; align-items: center; justify-content: center; line-height: 1.3; }
        @media (max-width: 575px) {
            .industry-tile .ind-img { height: 100px; }
            .industry-tile .ind-icon { width: 28px; height: 28px; font-size: 12px; }
            .industry-tile span { padding: 10px 8px; font-size: 12.5px; }
        }

        .services-section { background: #fff; }
        .service-card { background: #fff; border: 1px solid #eef0fb; border-radius: 18px; padding: 28px; height: 100%; transition: transform .28s ease, box-shadow .28s ease, border-top-color .28s ease; border-top: 3px solid transparent; }
        .service-card:hover { transform: translateY(-6px); box-shadow: 0 22px 50px rgba(15,23,42,.12); border-top-color: var(--c-primary); }
        .service-card .ico { transition: transform .28s ease; }
        .service-card:hover .ico { transform: scale(1.06) rotate(-3deg); }
        .service-card .ico { width: 50px; height: 50px; border-radius: 14px; background: linear-gradient(135deg, rgba(108,92,231,.1), rgba(0,184,217,.1)); color: var(--c-primary); display: grid; place-items: center; font-size: 20px; margin-bottom: 16px; }
        .service-card h5 { font-size: 18px; margin-bottom: 8px; }
        .service-card p { color: var(--c-muted); font-size: 14px; margin: 0; }

        .testimonials-section { background: #fff; }
        .testi-card { background: #fff; border-radius: 20px; padding: 30px; box-shadow: var(--shadow-md); height: 100%; position: relative; border: 1px solid #eef0fb; transition: transform .28s ease, box-shadow .28s ease; }
        .testi-card:hover { transform: translateY(-4px); box-shadow: 0 22px 50px rgba(15,23,42,.1); }
        .testi-card::before { content: '\201C'; position: absolute; top: 10px; right: 24px; font-size: 80px; line-height: 1; color: var(--c-primary); opacity: .12; font-family: Georgia, serif; }
        .testi-card .stars { color: #ffd166; margin-bottom: 14px; }
        .testi-card .quote { font-size: 15px; color: #334155; line-height: 1.7; margin-bottom: 22px; }
        .testi-card .who { display: flex; align-items: center; gap: 14px; }
        .testi-card .avatar { width: 48px; height: 48px; border-radius: 50%; background: var(--grad-cta); color: #fff; display: grid; place-items: center; font-weight: 800; }
        .testi-card .name { font-weight: 700; color: var(--c-dark); }
        .testi-card .role { font-size: 13px; color: var(--c-muted); }

        .faq-section { background: #fff; }
        .faq-item { background: var(--c-bg); border: 1px solid #eef0fb; border-radius: 14px; margin-bottom: 14px; overflow: hidden; transition: .2s; }
        .faq-item.open { background: #fff; border-color: var(--c-primary); box-shadow: var(--shadow-md); }
        .faq-item .q { width: 100%; background: transparent; border: 0; padding: 20px 24px; text-align: left; font-weight: 700; color: var(--c-dark); font-size: 15px; display: flex; justify-content: space-between; align-items: center; gap: 14px; cursor: pointer; }
        .faq-item .q i { transition: .25s; color: var(--c-primary); flex-shrink: 0; }
        .faq-item.open .q i { transform: rotate(45deg); }
        .faq-item .a { padding: 0 24px; max-height: 0; overflow: hidden; transition: max-height .25s, padding .25s; }
        .faq-item.open .a { padding: 0 24px 22px; max-height: 500px; }
        .faq-item .a p { color: #475569; font-size: 14.5px; margin: 0; line-height: 1.7; }

        .final-cta { background: var(--grad-hero); color: #fff; padding: 90px 0; position: relative; overflow: hidden; }
        .final-cta::before { content: ""; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1518684079-3c830dcef090?auto=format&fit=crop&w=1920&q=70'); background-size: cover; background-position: center; opacity: .15; mix-blend-mode: overlay; }
        .final-cta .container { position: relative; z-index: 2; }
        .final-cta h2 { color: #fff; font-size: clamp(28px, 4vw, 48px); }
        .final-cta p { color: #d6def0; font-size: 17px; max-width: 720px; margin: 14px auto 28px; }
        .final-cta .btn-primary-x { background: linear-gradient(90deg, #00ffe1, #00b8d9); color: #0b1742; font-weight: 800; padding: 16px 34px; border-radius: 999px; border: 0; box-shadow: 0 20px 40px rgba(0,255,225,.3); display: inline-flex; gap: 10px; align-items: center; }
        .final-cta .btn-primary-x:hover { transform: translateY(-3px); }

        footer { background: #060c25; color: #cbd5e1; padding: 70px 0 0; }
        footer h6 { color: #fff; font-weight: 700; margin-bottom: 16px; font-size: 15px; text-transform: uppercase; letter-spacing: .08em; }
        footer p, footer a, footer li { font-size: 14px; line-height: 1.8; }
        footer a { color: #cbd5e1; }
        footer a:hover { color: #00ffe1; }
        footer ul { list-style: none; padding: 0; margin: 0; }
        footer .socials a { width: 38px; height: 38px; border-radius: 10px; display: inline-grid; place-items: center; background: rgba(255,255,255,.06); color: #cbd5e1; transition: .2s; margin-right: 8px; }
        footer .socials a:hover { background: var(--grad-cta); color: #fff; }
        footer .bot { border-top: 1px solid rgba(255,255,255,.08); margin-top: 50px; padding: 22px 0; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; font-size: 13px; }
        footer .bot .emp { color: #00ffe1; }

        .office-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 8px; }
        .office-card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px; display: flex; gap: 12px; transition: .2s; }
        .office-card:hover { background: rgba(255,255,255,.07); border-color: rgba(0,255,225,.3); }
        .office-flag { font-size: 26px; line-height: 1; width: 40px; height: 40px; display: grid; place-items: center; background: rgba(255,255,255,.06); border-radius: 10px; flex-shrink: 0; }
        .office-body { flex: 1; min-width: 0; }
        .office-title { color: #fff; font-weight: 700; font-size: 14px; margin-bottom: 6px; }
        .office-line { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: #cbd5e1; line-height: 1.5; margin-bottom: 4px; text-decoration: none; }
        .office-line i { color: #00ffe1; font-size: 13px; margin-top: 3px; flex-shrink: 0; }
        a.office-line:hover { color: #00ffe1; }

        @media (max-width: 575px) { .office-grid { grid-template-columns: 1fr; } }

        .wa-float { position: fixed; left: 20px; bottom: 24px; z-index: 9999; width: 60px; height: 60px; border-radius: 50%; background: #25D366; color: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 22px rgba(37,211,102,.5); animation: wa-pulse 2s ease-in-out infinite; text-decoration: none; }
        .wa-float:hover { color: #fff; transform: scale(1.08); }
        @keyframes wa-pulse { 0%,100% { box-shadow: 0 6px 22px rgba(37,211,102,.5); } 50% { box-shadow: 0 6px 28px rgba(37,211,102,.65), 0 0 0 14px rgba(37,211,102,.12); } }
        @media (max-width: 575px) { .wa-float { width: 52px; height: 52px; left: 14px; bottom: 18px; } .wa-float i { font-size: 24px !important; } }

        /* Responsive */
        @media (max-width: 1199px) { .section-pad { padding: 70px 0; } }
        @media (max-width: 991px) {
            .hero { padding: 56px 0 80px; }
            .hero h1 { font-size: 36px !important; }
            .hero .lead { font-size: 15px; }
            .hero-form-card { margin-top: 30px; padding: 26px; }
            .stats-strip { margin-top: -34px; }
            .stats-card { padding: 22px 16px; }
            .stats-card .num { font-size: 26px; }
            .section-pad { padding: 60px 0; }
            .section-title { font-size: 28px !important; }
        }
        @media (max-width: 767px) {
            .hero { padding: 40px 0 70px; }
            .hero h1 { font-size: 30px !important; line-height: 1.15; }
            .hero .lead { font-size: 14.5px; }
            .hero .feature-pills li { font-size: 12px; padding: 6px 10px; }
            .hero .btn-primary-x, .hero .btn-ghost-x { padding: 12px 20px; font-size: 14px; }
            .hero-form-card { padding: 22px; border-radius: 18px; }
            .hero-form-card h3 { font-size: 19px; }
            .stats-strip { margin-top: -28px; }
            .stats-card .num { font-size: 22px; }
            .stats-card .lbl { font-size: 11.5px; }
            .section-pad { padding: 50px 0; }
            .section-title { font-size: 24px !important; }
            .section-sub { font-size: 14.5px; }
            .feature-card, .service-card, .step-card, .testi-card { padding: 22px; }
            .product-card { padding: 18px; }
            .industry-tile { padding: 16px 10px; font-size: 13px; }
            .compare-table thead th, .compare-table tbody td { font-size: 12px; padding: 10px 8px; }
            .faq-item .q { font-size: 14px; padding: 16px 18px; }
            .faq-item .a { padding: 0 18px; }
            .faq-item.open .a { padding: 0 18px 18px; }
            .testi-card .quote { font-size: 14px; }
            .final-cta { padding: 60px 0; }
            footer { padding-top: 50px; }
            footer .bot { flex-direction: column; align-items: flex-start; text-align: left; gap: 6px; }
        }
        @media (max-width: 575px) {
            html, body { overflow-x: hidden; }
            .container { padding-left: 16px; padding-right: 16px; }
            .hero h1 { font-size: 26px !important; }
            .hero .badge-pill { font-size: 11.5px; padding: 6px 12px; }
            .hero .feature-pills { gap: 6px; }
            .hero .hero-ctas { flex-direction: column; }
            .hero .btn-primary-x, .hero .btn-ghost-x { width: 100%; justify-content: center; display: flex; }
            .hero .trust-row { font-size: 13px; flex-wrap: wrap; }
            .hero-form-card { padding: 20px; }
            .hero-form-card .col-6 { flex: 0 0 100%; max-width: 100%; }
            .stats-card { padding: 16px 10px; gap: 10px; }
            .stats-card .num { font-size: 20px; }
            .stats-card .lbl { font-size: 11px; }
            .section-title { font-size: 22px !important; }
            .section-sub { font-size: 13.5px; }
            .eyebrow { font-size: 10.5px; padding: 6px 10px; }
            .product-card { padding: 16px; }
            .product-card .head { gap: 10px; }
            .product-card .logo-box { width: 44px; height: 44px; }
            .testi-card { padding: 20px; }
            .compare-table thead th, .compare-table tbody td { font-size: 11px; padding: 8px 6px; }
            .final-cta h2 { font-size: 24px; }
            .industry-tile { padding: 14px 8px; font-size: 12.5px; }
            .industry-tile .ico { width: 38px; height: 38px; font-size: 16px; }
            .office-card { padding: 12px; }
            .office-flag { width: 36px; height: 36px; font-size: 22px; }
        }
        @media (max-width: 380px) {
            .hero h1 { font-size: 23px !important; }
            .stats-card { grid-template-columns: 1fr 1fr; }
            .stats-card .stat:nth-child(2) { border-right: 0; }
            .section-title { font-size: 20px !important; }
            .product-card h5 { font-size: 15px; }
            .compare-table { font-size: 10.5px; }
            .compare-table thead th { font-size: 10px; padding: 8px 4px; }
            .compare-table tbody td { font-size: 10.5px; padding: 6px 4px; }
        }

        /* ========= Auto-open lead modal ========= */
        .rq-modal-overlay { position: fixed; inset: 0; background: rgba(11,23,66,.55); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 2147483640; opacity: 0; visibility: hidden; transition: opacity .3s ease, visibility .3s ease; }
        .rq-modal-overlay.show { opacity: 1; visibility: visible; }
        .rq-modal { position: fixed; top: 50%; left: 50%; -webkit-transform: translate(-50%, -45%) scale(.96); transform: translate(-50%, -45%) scale(.96); width: min(94vw, 960px); max-height: 88vh; background: #fff; border-radius: 24px; box-shadow: 0 30px 80px rgba(0,0,0,.4); z-index: 2147483641; opacity: 0; visibility: hidden; transition: opacity .35s ease, transform .35s cubic-bezier(.2,1.05,.4,1.05), visibility .35s ease; overflow: hidden; }
        .rq-modal.show { opacity: 1; visibility: visible; -webkit-transform: translate(-50%, -50%) scale(1); transform: translate(-50%, -50%) scale(1); }
        .rq-grid { display: grid; grid-template-columns: 1.05fr 1fr; max-height: 88vh; }
        .rq-left { background: linear-gradient(160deg, #eef3ff 0%, #fff 100%); padding: 30px 28px; overflow-y: auto; -webkit-overflow-scrolling: touch; }
        .rq-right { padding: 30px 28px; overflow-y: auto; -webkit-overflow-scrolling: touch; position: relative; }
        .rq-eyebrow { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .14em; color: #4f46e5; background: rgba(79,70,229,.08); padding: 7px 14px; border-radius: 999px; text-transform: uppercase; margin-bottom: 14px; }
        .rq-left h2 { font-size: 24px; font-weight: 800; color: #0b1742; line-height: 1.2; margin: 0 0 20px; letter-spacing: -.01em; }
        .rq-flags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
        .rq-flags span { background: #fff; border: 1px solid #e2e8f0; border-radius: 999px; padding: 6px 12px; font-size: 13px; font-weight: 600; color: #1a1f3a; display: inline-flex; align-items: center; gap: 6px; box-shadow: 0 2px 6px rgba(0,0,0,.03); }
        .rq-testimonial { background: #fff; border-radius: 14px; padding: 20px; box-shadow: 0 4px 16px rgba(0,0,0,.04); color: #334155; font-size: 14px; line-height: 1.6; margin-bottom: 14px; border: 1px solid #eef0fb; }
        .rq-author { display: flex; align-items: center; gap: 12px; padding: 4px 4px 18px; }
        .rq-avatar { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, #f97316, #ef4444); color: #fff; display: grid; place-items: center; font-weight: 800; font-size: 14px; flex-shrink: 0; }
        .rq-name { font-weight: 700; color: #0b1742; font-size: 14px; }
        .rq-role { font-size: 12px; color: #64748b; margin-top: 2px; }
        .rq-clients-title { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #64748b; margin: 32px 0 12px; }
        .rq-clients-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
        .rq-client { background: #fff; border: 1px solid #eef0fb; border-radius: 10px; padding: 10px 8px; display: flex; align-items: center; justify-content: center; transition: .2s; min-height: 64px; }
        .rq-client:hover { border-color: #6c5ce7; transform: translateY(-2px); box-shadow: 0 6px 14px rgba(0,0,0,.06); }
        .rq-client img { max-width: 100%; max-height: 32px; object-fit: contain; }

        .rq-partner-badges { display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid #eef0fb; border-radius: 16px; padding: 10px 14px; margin-bottom: 22px; width: fit-content; }
        .rq-partner-badges img.zoho-logo { height: 30px; }
        .rq-partner-badges img.auth-badge { height: 44px; }
        .rq-right h3 { font-size: 22px; font-weight: 800; color: #0b1742; margin: 0 0 6px; letter-spacing: -.01em; }
        .rq-right .rq-sub { color: #64748b; font-size: 14px; margin: 0 0 22px; }
        .rq-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
        .rq-field { display: flex; flex-direction: column; }
        .rq-field label { font-size: 13px; font-weight: 600; color: #1a1f3a; margin-bottom: 6px; }
        .rq-field label .req { color: #ef4444; }
        .rq-field input, .rq-field select, .rq-field textarea { border: 1.5px solid #e3e8f5; border-radius: 12px; padding: 11px 14px; background: #fff; font-size: 14px; color: #1a1f3a; font-family: inherit; transition: .2s; width: 100%; -webkit-appearance: none; appearance: none; }
        .rq-field select { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2364748b' stroke-width='2' stroke-linecap='round'><polyline points='6 9 12 15 18 9'/></svg>"); background-repeat: no-repeat; background-position: right 12px center; background-size: 16px; padding-right: 36px; }
        .rq-field input:focus, .rq-field select:focus, .rq-field textarea:focus { border-color: #6c5ce7; outline: none; box-shadow: 0 0 0 4px rgba(108,92,231,.12); }
        .rq-field textarea { min-height: 90px; resize: vertical; line-height: 1.5; }
        .rq-note { font-size: 12px; color: #64748b; margin: 12px 0 14px; line-height: 1.5; }
        .rq-note a { color: #4f46e5; font-weight: 600; }
        .rq-submit { background: linear-gradient(120deg, #2563eb, #4f46e5); color: #fff; border: 0; border-radius: 999px; padding: 14px; width: 100%; font-weight: 700; font-size: 15px; cursor: pointer; transition: .2s; box-shadow: 0 12px 25px rgba(37,99,235,.25); font-family: inherit; }
        .rq-submit:hover { transform: translateY(-2px); }
        .rq-submit:disabled { opacity: .7; cursor: wait; }
        .rq-close { position: absolute; top: 14px; right: 14px; width: 36px; height: 36px; border-radius: 50%; background: rgba(11,23,66,.06); border: 0; color: #1a1f3a; font-size: 18px; cursor: pointer; z-index: 10; transition: .2s; display: grid; place-items: center; -webkit-appearance: none; appearance: none; }
        .rq-close:hover { background: rgba(11,23,66,.12); transform: rotate(90deg); }
        .rq-success { background: #dcfce7; color: #065f46; border: 1px solid #bbf7d0; padding: 14px; border-radius: 12px; font-size: 14px; margin-top: 12px; display: none; }
        .rq-success.show { display: block; }
        body.rq-modal-open { overflow: hidden; }
        @media (max-width: 880px) {
            .rq-grid { grid-template-columns: 1fr; max-height: 100vh; }
            .rq-left { display: none; }
            .rq-modal { max-height: 96vh; width: 96vw; border-radius: 18px; }
            .rq-right { padding: 22px 18px 18px; max-height: 96vh; }
            .rq-right h3 { font-size: 18px; margin-bottom: 4px; }
            .rq-right .rq-sub { font-size: 13px; margin-bottom: 14px; }
            .rq-row { grid-template-columns: 1fr; gap: 8px; margin-bottom: 8px; }
            .rq-field label { font-size: 12.5px; margin-bottom: 4px; }
            .rq-field input, .rq-field select, .rq-field textarea { padding: 10px 12px; font-size: 13.5px; }
            .rq-close { background: #f1f5f9; top: 10px; right: 10px; }
            .rq-partner-badges { padding: 6px 10px; margin-bottom: 14px; }
            .rq-partner-badges img.zoho-logo { height: 22px; }
            .rq-partner-badges img.auth-badge { height: 32px; }
            .rq-submit { padding: 12px; font-size: 14px; margin-top: 6px; }
            .rq-hide-mobile { display: none !important; }
        }
    </style>
</head>

