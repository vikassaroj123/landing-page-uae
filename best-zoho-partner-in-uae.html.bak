    <!-- Comparison -->
    <section class="compare-section section-pad">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="eyebrow">How We Compare</span>
                <h2 class="section-title">Zoho vs. <span class="text-grad">SAP, Microsoft, Oracle &amp; Local UAE Apps</span></h2>
                <p class="section-sub">Why UAE SMEs and mid-market teams pick Zoho over enterprise giants and finance-only local tools.</p>
            </div>

            <div class="compare-table table-responsive" data-aos="fade-up">
                <table class="table mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="text-start">Feature</th>
                            <th class="best">Zoho Suite</th>
                            <th>SAP / MS Dynamics</th>
                            <th>Oracle NetSuite</th>
                            <th>Tally / QuickBooks / Local</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Integrated Apps</td><td class="best">45+ apps under one subscription</td><td>Modules licensed separately</td><td>Powerful but complex</td><td>Mostly finance only</td></tr>
                        <tr><td>Customization</td><td class="best">Low-code (Creator) + Deluge + APIs</td><td>Power Platform / SAP BTP</td><td>Needs deep partner support</td><td>Limited customization</td></tr>
                        <tr><td>UAE VAT &amp; FTA e-invoicing</td><td class="best">Built-in 5% VAT, VAT201, e-invoicing-ready</td><td>Via partner add-ons</td><td>Enterprise-grade, expensive</td><td>VAT-ready but limited</td></tr>
                        <tr><td>WPS &amp; EOSB Payroll</td><td class="best">UAE Payroll edition: WPS + EOSB + GPSSA</td><td>Heavy integration needed</td><td>Enterprise customization</td><td>Often needs add-ons</td></tr>
                        <tr><td>Arabic / RTL UI</td><td class="best">Full Arabic UI + bilingual templates</td><td>Partial / configured</td><td>Enterprise localization</td><td>Limited</td></tr>
                        <tr><td>Total Cost (TCO)</td><td class="best">Lower with multi-app use</td><td>High licenses + connectors</td><td>Premium pricing</td><td>Cheap entry, scales costly</td></tr>
                        <tr><td>Best Fit</td><td class="best">SMB → mid-market in UAE</td><td>Enterprises tied to MS / SAP</td><td>Large global enterprises</td><td>Finance-only deployments</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Services -->
