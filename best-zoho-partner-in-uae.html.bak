            </div>
        </div>
    </div>

    <a href="https://wa.me/919565153545" class="wa-float" target="_blank" rel="noopener" aria-label="WhatsApp Chat">
        <i class="fa-brands fa-whatsapp" style="font-size:28px;"></i>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>

        // Mobile drawer
        (function () {
            const navToggle = document.getElementById('navToggle');
            const navToggleIcon = document.getElementById('navToggleIcon');
            const mobileMenu = document.getElementById('mobileMenu');
            const mobileOverlay = document.getElementById('mobileOverlay');
            const mmClose = document.getElementById('mmClose');
            if (!navToggle || !mobileMenu || !mobileOverlay) return;
            let scrollY = 0;
            const openMenu = (e) => {
                if (e) { e.preventDefault(); e.stopPropagation(); }
                scrollY = window.scrollY || 0;
                mobileMenu.classList.add('show'); mobileOverlay.classList.add('show');
                document.body.style.top = '-' + scrollY + 'px';
                document.body.classList.add('menu-open');
                navToggle.setAttribute('aria-expanded', 'true');
                if (navToggleIcon) { navToggleIcon.classList.remove('fa-bars'); navToggleIcon.classList.add('fa-xmark'); }
                mobileMenu.setAttribute('aria-hidden', 'false');
            };
            const closeMenu = (e) => {
                if (e) { e.preventDefault(); e.stopPropagation(); }
                mobileMenu.classList.remove('show'); mobileOverlay.classList.remove('show');
                document.body.classList.remove('menu-open');
                document.body.style.top = '';
                window.scrollTo(0, scrollY);
                navToggle.setAttribute('aria-expanded', 'false');
                if (navToggleIcon) { navToggleIcon.classList.add('fa-bars'); navToggleIcon.classList.remove('fa-xmark'); }
                mobileMenu.setAttribute('aria-hidden', 'true');
            };
            const toggleMenu = (e) => mobileMenu.classList.contains('show') ? closeMenu(e) : openMenu(e);
            navToggle.addEventListener('click', toggleMenu);
            navToggle.addEventListener('touchend', (e) => { e.preventDefault(); toggleMenu(e); }, { passive: false });
            if (mmClose) {
                mmClose.addEventListener('click', closeMenu);
                mmClose.addEventListener('touchend', (e) => { e.preventDefault(); closeMenu(e); }, { passive: false });
            }
            mobileOverlay.addEventListener('click', closeMenu);
            document.querySelectorAll('.mm-close-on-click').forEach(a => a.addEventListener('click', () => setTimeout(closeMenu, 50)));
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
            window.addEventListener('resize', () => { if (window.innerWidth >= 992 && mobileMenu.classList.contains('show')) closeMenu(); });
        })();

        // Language dropdown
        const langSwitch = document.getElementById('langSwitch');
        const langBtn = document.getElementById('langBtn');
        if (langBtn) {
            langBtn.addEventListener('click', (e) => { e.stopPropagation(); langSwitch.classList.toggle('open'); });
            document.addEventListener('click', () => langSwitch.classList.remove('open'));
        }

        // FAQ accordion
        document.querySelectorAll('.faq-item .q').forEach(btn => {
            btn.addEventListener('click', () => {
                const item = btn.parentElement;
                const wasOpen = item.classList.contains('open');
                document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
                if (!wasOpen) item.classList.add('open');
            });
        });

        // Stats counter
        const counters = document.querySelectorAll('.stats-card .num .text-grad');
        const animate = (el) => {
            const target = el.textContent;
            const isPct = target.includes('%'); const isPlus = target.includes('+');
            const num = parseInt(target.replace(/\D/g, ''), 10);
            if (!num) return;
            let start = 0;
            const step = Math.max(1, Math.ceil(num / 50));
            const tick = () => {
                start += step;
                if (start >= num) { el.textContent = num + (isPct ? '%' : (isPlus ? '+' : '')); return; }
                el.textContent = start + (isPct ? '%' : (isPlus ? '+' : ''));
                requestAnimationFrame(tick);
            };
            tick();
        };
        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => { if (e.isIntersecting) { animate(e.target); io.unobserve(e.target); } });
        }, { threshold: .4 });
        counters.forEach(c => io.observe(c));

        // Zoho Web-to-Lead
        (function () {
            const ZDC = 'com';
            const form = document.getElementById('bannerCrmForm');
            const thanks = document.getElementById('bannerThanks');
            const iframe = document.getElementById('bannerCrmTarget');
            const submit = document.getElementById('bannerSubmitBtn');

            form.setAttribute('action', 'https://crm.zoho.' + ZDC + '/crm/WebToLeadForm');
            document.getElementById('banner_returnURL').value = location.origin + location.pathname + '?submitted=1#hero-thanks';
            (function () {
                const zc = document.getElementById('banner_zc_gad'); if (!zc) return;
                const qs = new URLSearchParams(location.search);
                const id = qs.get('gclid') || qs.get('wbraid') || qs.get('gbraid');
                if (id) zc.value = id;
            })();

            const splitName = (n) => {
                const parts = (n || '').trim().split(/\s+/).filter(Boolean);
                if (!parts.length) return { first: '', last: '' };
                if (parts.length === 1) return { first: '', last: parts[0] };
                return { first: parts.slice(0, -1).join(' '), last: parts[parts.length - 1] };
            };
            const isValidEmail = (e) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
            let submitted = false, conversionSent = false;
            const showSuccess = () => {
                thanks.innerHTML = '<div class="alert alert-success mb-0" style="background:#dcfce7;color:#065f46;border:1px solid #bbf7d0;padding:14px;border-radius:12px;font-size:14px;"><i class="fa-solid fa-circle-check me-2"></i>Thank you! We will contact you within 4 working hours.</div>';
                thanks.style.display = '';
                submit.disabled = true;
                if (!conversionSent && typeof gtag_report_conversion === 'function') { conversionSent = true; gtag_report_conversion(); }
                try { thanks.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); } catch (e) { }
            };
            const showFieldError = (f, m) => {
                const d = document.createElement('div'); d.className = 'error-message text-danger small mt-1'; d.textContent = m;
                f.parentNode.appendChild(d);
            };
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const hp = form.querySelector('[name="aG9uZXlwb3Q"]').value;
                if (hp && hp.trim()) return;
                const fullName = document.getElementById('fullName');
                const phone = document.getElementById('phoneNumber');
                const email = document.getElementById('email');
                document.querySelectorAll('.error-message').forEach(el => el.remove());
                document.querySelectorAll('.form-control').forEach(el => el.classList.remove('is-invalid'));
                let valid = true;
                if (!fullName.value.trim()) { fullName.classList.add('is-invalid'); showFieldError(fullName, 'Please enter your full name'); valid = false; }
                if (!phone.value.trim()) { phone.classList.add('is-invalid'); showFieldError(phone, 'Please enter your phone number'); valid = false; }
                if (!email.value.trim()) { email.classList.add('is-invalid'); showFieldError(email, 'Please enter your email'); valid = false; }
                else if (!isValidEmail(email.value)) { email.classList.add('is-invalid'); showFieldError(email, 'Please enter a valid email'); valid = false; }
                if (!valid) return;
                const parts = splitName(fullName.value);
                document.getElementById('banner_First_Name').value = parts.first;
                document.getElementById('banner_Last_Name').value = parts.last;
                submitted = true;
                form.submit();
                setTimeout(() => { if (submitted && thanks.style.display === 'none') showSuccess(); }, 1200);
            });
            iframe.addEventListener('load', () => { if (submitted) { showSuccess(); submitted = false; } });
        })();

        // ===== Auto-open Lead Modal (40s recurring) =====
        (function () {
            const overlay = document.getElementById('rqModalOverlay');
            const modal = document.getElementById('rqModal');
            const closeBtn = document.getElementById('rqClose');
            const form = document.getElementById('rqModalForm');
            const submit = document.getElementById('rqSubmit');
            const success = document.getElementById('rqSuccess');
            const iframe = document.getElementById('rqModalIframe');
            if (!overlay || !modal) return;
            const SUBMITTED_KEY = 'rqModalSubmitted';
            const REOPEN_MS = 40000;
            let modalTimer = null;
            const isSubmitted = () => { try { return !!sessionStorage.getItem(SUBMITTED_KEY); } catch(e) { return false; } };
            const markSubmitted = () => { try { sessionStorage.setItem(SUBMITTED_KEY, '1'); } catch(e) {} };
            const open = () => { if (isSubmitted()) return; modal.classList.add('show'); overlay.classList.add('show'); document.body.classList.add('rq-modal-open'); };
            const scheduleNext = () => { if (modalTimer) { clearTimeout(modalTimer); modalTimer = null; } if (isSubmitted()) return; modalTimer = setTimeout(open, REOPEN_MS); };
            const close = () => { modal.classList.remove('show'); overlay.classList.remove('show'); document.body.classList.remove('rq-modal-open'); scheduleNext(); };
            scheduleNext();
            closeBtn.addEventListener('click', close);
            overlay.addEventListener('click', close);
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('show')) close(); });
            form.setAttribute('action', 'https://crm.zoho.com/crm/WebToLeadForm');
            document.getElementById('rq_returnURL').value = location.origin + location.pathname + '?modal=1';
            const splitName = (n) => { const parts = (n || '').trim().split(/\s+/).filter(Boolean); if (!parts.length) return { first: '', last: '' }; if (parts.length === 1) return { first: '', last: parts[0] }; return { first: parts.slice(0, -1).join(' '), last: parts[parts.length - 1] }; };
            const isValidEmail = (e) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
            let submitted = false;
            const showSuccessMsg = () => { success.classList.add('show'); submit.disabled = true; submit.textContent = 'Submitted ✓'; if (typeof gtag_report_conversion === 'function') gtag_report_conversion(); markSubmitted(); if (modalTimer) { clearTimeout(modalTimer); modalTimer = null; } setTimeout(() => { modal.classList.remove('show'); overlay.classList.remove('show'); document.body.classList.remove('rq-modal-open'); }, 2400); };
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                const hp = form.querySelector('[name="aG9uZXlwb3Q"]').value;
                if (hp && hp.trim()) return;
                const fn = document.getElementById('rqFullName');
                const phone = document.getElementById('rqPhone');
                const email = document.getElementById('rqEmail');
                const country = document.getElementById('rqCountry');
                const service = document.getElementById('rqService');
                const details = document.getElementById('rqDetails');
                let valid = true;
                [fn, phone, email].forEach(f => f.style.borderColor = '');
                if (!fn.value.trim()) { fn.style.borderColor = '#ef4444'; valid = false; }
                if (!phone.value.trim()) { phone.style.borderColor = '#ef4444'; valid = false; }
                if (!email.value.trim() || !isValidEmail(email.value)) { email.style.borderColor = '#ef4444'; valid = false; }
                if (!valid) return;
                const parts = splitName(fn.value);
                document.getElementById('rq_First_Name').value = parts.first;
                document.getElementById('rq_Last_Name').value = parts.last;
                const meta = [];
                if (country.value.trim()) meta.push('Country: ' + country.value.trim());
                if (service.value) meta.push('Service: ' + service.value);
                const finalDesc = (meta.length ? meta.join('\n') + '\n\n' : '') + (details.value || '');
                details.value = finalDesc;
                submitted = true;
                form.submit();
                setTimeout(() => { if (submitted && !success.classList.contains('show')) showSuccessMsg(); }, 1200);
            });
            iframe.addEventListener('load', () => { if (submitted) { showSuccessMsg(); submitted = false; } });
        })();
    </script>
</body>
</html>
