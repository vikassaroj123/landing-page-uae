    <!-- Process -->
    <section class="process-section section-pad">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <span class="eyebrow" style="background: rgba(0,255,225,.12); color:#00ffe1;">Our Process</span>
                <h2 class="section-title">A predictable <span style="color:#00ffe1;">implementation path</span></h2>
                <p class="section-sub">Low-risk delivery from kickoff to go-live and beyond.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3" data-aos="fade-up"><div class="step-card"><div class="num">01</div><h5>Discovery &amp; Scope</h5><p>Stakeholder workshops, process mapping, written scope &amp; success metrics.</p></div></div>
